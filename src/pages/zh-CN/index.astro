---
/**
 * Hagicode 首页
 * 集成所有首页组件,展示产品特性和功能
 */
import Navbar from '@/components/home/Navbar';
import HeroSection from '@/components/home/HeroSection';
import ActivityMetricsSection from '@/components/home/ActivityMetricsSection';
import FeaturesShowcase from '@/components/home/FeaturesShowcase';
import ShowcaseSection from '@/components/home/ShowcaseSection';
import VideoShowcase from '@/components/home/VideoShowcase';
import type {
  FeaturedVideosByProvider,
  VideoShowcaseItem,
} from '@/components/home/VideoShowcase';
import PricingComparisonSection from '@/components/home/PricingComparisonSection';
import ProductHuntBadgeSection from '@/components/home/ProductHuntBadgeSection';
import { PromoteCard } from '@/components/promote/PromoteCard';
import promoteCardStyles from '@/components/promote/PromoteCard.module.css';
import LiveBroadcastSection from '@/components/home/LiveBroadcastSection';
import Footer from '@/components/home/Footer';
import LunarNewYearDecorations from '@/components/home/LunarNewYearDecorations';
import AnalyticsScripts from '@/components/AnalyticsScripts.astro';
import GoogleAnalytics from '@/components/GoogleAnalytics.astro';
import { FEATURE_LIVE_BROADCAST_ENABLED } from '@/config/features';
import { getBundledLiveBroadcastData } from '@/lib/live-broadcast-source';
// 导入首页样式
import '@/styles/homepage.css';

import { getAbsoluteSiteUrl } from "@/lib/locale-routing";

// 页面元数据
const title = 'Hagicode - 智能 · 高效 · 有趣的 AI 编码助手';
const description = '用 AI 重新定义代码开发体验。OpenSpec 工作流、多 Agent 多实例并行、Hero Dungeon 游戏化，让编码更高效、更有趣';

// 获取当前语言环境
const currentLocale = 'zh-CN';

// 获取站点基础路径
const siteBase = import.meta.env.VITE_SITE_BASE || '';

// 直接构造完整的 URL 字符串，避免 new URL 的路径解析问题
const canonicalUrl = getAbsoluteSiteUrl('/', 'zh-CN', siteBase);
const englishUrl = getAbsoluteSiteUrl('/', 'en', siteBase);
const liveBroadcastData = FEATURE_LIVE_BROADCAST_ENABLED ? getBundledLiveBroadcastData() : null;

const featuredHomepageVideos: FeaturedVideosByProvider = {
  youtube: {
    provider: 'youtube',
    embedId: 'AQ8oSTW6wNQ',
    title: 'Hagicode 英文完整介绍（YouTube）',
    description:
      '当浏览器偏好英文时，首页会优先显示这条 YouTube 主介绍视频，先讲清 Hagicode 的整体工作流、产品定位和多 Agent 协作体验。',
    watchUrl: 'https://www.youtube.com/watch?v=AQ8oSTW6wNQ',
    ctaLabel: '打开 YouTube',
  },
  bilibili: {
    provider: 'bilibili',
    embedId: 'BV1z4oWB3EpY',
    title: 'Hagicode 中文完整介绍（Bilibili）',
    description:
      '中文浏览器默认会看到这条 Bilibili 主介绍视频，用最直接的中文讲清 Hagicode 的核心路线、能力边界和真实使用方式。',
    watchUrl: 'https://www.bilibili.com/video/BV1z4oWB3EpY/',
    ctaLabel: '打开 Bilibili',
  },
};

const supportingHomepageVideos: VideoShowcaseItem[] = [
  {
    provider: 'bilibili',
    embedId: 'BV1KxwMzxEVK',
    title: 'AI 居然 写代码时 玩游戏',
    description: '作为补充演示，这条视频更偏趣味互动，帮助你快速感受 Hagicode 在真实编码过程里的节奏和氛围。',
    watchUrl: 'https://www.bilibili.com/video/BV1KxwMzxEVK/',
    ctaLabel: '打开 Bilibili',
  },
  {
    title: 'GPT Codex in Hagicode 实测',
    provider: 'bilibili',
    embedId: 'BV1yqPmzTEqP',
    description: '聚焦 GPT Codex 在 Hagicode 中的实际表现，帮助你在主介绍之外继续判断模型接入后的真实效果。',
    watchUrl: 'https://www.bilibili.com/video/BV1yqPmzTEqP/',
    ctaLabel: '打开 Bilibili',
  },
];

---

<!doctype html>
<html lang={currentLocale} data-site-base={siteBase}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <!-- SEO hreflang tags -->
    <link rel="alternate" hreflang="zh-CN" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="x-default" href={englishUrl} />
    <!-- 百度搜索引擎验证 -->
    <meta name="baidu-site-verification" content="codeva-A9s3yT3z5m" />
    <meta name="og:title" content={title} />
    <meta name="og:description" content={description} />
    <meta name="og:type" content="website" />
    <GoogleAnalytics />
    <script is:inline>
      // 禁用浏览器的自动滚动恢复，并强制滚动到顶部
      // 防止刷新页面后跳到之前的滚动位置
      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'manual';
      }
      // 立即滚动到顶部
      window.scrollTo(0, 0);

      // 初始化主题 - 在页面加载前执行，避免闪烁
      // 与 Starlight 文档站同步使用 starlight-theme 键
      (function() {
        // 判断是否在农历新年期间
        // 蛇年2025: 2025-01-29 至 2025-02-12 (元宵节)
        // 马年2026: 2026-02-17 至 2026-03-03 (元宵节)
        function isLunarNewYearPeriod() {
          const now = new Date();
          const year = now.getFullYear();
          const month = now.getMonth() + 1; // 1-12
          const day = now.getDate();

          // 2025年蛇年新年期间 (1月29日 - 2月12日)
          if (year === 2025) {
            if (month === 1 && day >= 29) return true;
            if (month === 2 && day <= 12) return true;
          }
          // 2026年马年新年期间 (2月17日 - 3月3日)
          if (year === 2026) {
            if (month === 2 && day >= 17) return true;
            if (month === 3 && day <= 3) return true;
          }
          return false;
        }

        const stored = localStorage.getItem('starlight-theme');
        const system = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        let theme;

        if (stored) {
          // 用户已有主题偏好,使用其选择
          theme = stored;
        } else {
          // 用户无主题偏好,应用智能默认
          theme = isLunarNewYearPeriod() ? 'lunar-new-year' : system;
        }

        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="homepage">
    <!-- 新年主题装饰 - 仅在农历新年主题下显示 -->
    <LunarNewYearDecorations client:load />

    <Navbar client:load locale="zh-CN" />

    <main class="homepage" id="homepage-content" data-homepage-locale={currentLocale}>
      <!-- Hero Section - 首屏必需 -->
      <HeroSection locale="zh-CN" client:load />

      {FEATURE_LIVE_BROADCAST_ENABLED && (
        <LiveBroadcastSection
          locale="zh-CN"
          enabled={FEATURE_LIVE_BROADCAST_ENABLED}
          initialData={liveBroadcastData}
          client:load
        />
      )}

      <!-- Activity Metrics Section -->
      <ActivityMetricsSection locale="zh-CN" client:load />

      <!-- Features Showcase -->
      <FeaturesShowcase locale="zh-CN" client:load />

      <!-- Copilot CLI Integration Entry -->

      <!-- Showcase Section -->
      <ShowcaseSection locale="zh-CN" client:load />

      <!-- Video Showcase -->
      <VideoShowcase
        locale={currentLocale}
        eyebrow="真实视频演示"
        title="视频实测：看看 Hagicode 真正怎么工作"
        description="先看按浏览器语言匹配的主介绍视频，再补充两条专题演示；就算嵌入播放器加载慢或被拦截，标题、摘要和平台按钮也会把信息说清楚。"
        featuredLabel="主推荐视频"
        supportingLabel="补充演示"
        featuredVideos={featuredHomepageVideos}
        supportingVideos={supportingHomepageVideos}
        client:load
      />

      <!-- Pricing Comparison Section -->
      <PricingComparisonSection locale="zh-CN" client:load />

      <!-- Product Hunt trust surface -->
      <ProductHuntBadgeSection locale="zh-CN" />

    </main>

    <PromoteCard locale="zh-CN" className={promoteCardStyles.promoteCard} client:load />

    <!-- Footer -->
    <Footer locale="zh-CN" client:load />

    <AnalyticsScripts />
  </body>
</html>
