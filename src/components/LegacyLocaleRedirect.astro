---
import { getAbsoluteSiteUrl, joinWithSiteBase } from '@/lib/locale-routing';

interface Props {
  targetPath: string;
  destinationName: string;
  movedCopy: string;
}

const { targetPath, destinationName, movedCopy } = Astro.props;
const siteBase = import.meta.env.VITE_SITE_BASE || '';
const redirectPath = joinWithSiteBase(siteBase, targetPath);
const canonicalUrl = getAbsoluteSiteUrl(targetPath, 'en', siteBase);
const title = `${destinationName} has moved`;
const description = `This legacy English URL now points to ${destinationName} at ${redirectPath}. ${movedCopy}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <script is:inline define:vars={{ redirectPath }}>
      const nextUrl = `${redirectPath}${window.location.search}${window.location.hash}`;
      window.location.replace(nextUrl);
    </script>
  </head>
  <body class="redirect-page">
    <main class="redirect-card">
      <p class="redirect-eyebrow">Legacy English alias</p>
      <h1>This page has moved</h1>
      <p class="redirect-copy">{movedCopy}</p>
      <p class="redirect-copy">
        Continue to <a href={redirectPath}>{destinationName}</a> at <code>{redirectPath}</code>.
      </p>
      <a class="redirect-cta" href={redirectPath}>Continue to the current page</a>
    </main>
  </body>
</html>

<style>
  :global(html),
  :global(body.redirect-page) {
    min-height: 100%;
    margin: 0;
    background:
      radial-gradient(circle at top, rgba(37, 194, 160, 0.18), transparent 52%),
      linear-gradient(180deg, #07111d 0%, #04070d 100%);
    color: #f8fafc;
    font-family: "DM Sans", system-ui, sans-serif;
  }

  .redirect-page {
    display: grid;
    min-height: 100vh;
    place-items: center;
    padding: 1.5rem;
  }

  .redirect-card {
    width: min(100%, 42rem);
    padding: 2.5rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 1.5rem;
    background: rgba(15, 23, 42, 0.78);
    box-shadow: 0 20px 60px rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(18px);
  }

  .redirect-eyebrow {
    margin: 0 0 1rem;
    color: #5eead4;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: clamp(2rem, 6vw, 3rem);
    line-height: 1.1;
  }

  .redirect-copy {
    margin: 0 0 1rem;
    color: rgba(226, 232, 240, 0.88);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  code {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.95em;
    color: #bfdbfe;
  }

  a {
    color: #67e8f9;
  }

  .redirect-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #22c55e 0%, #06b6d4 100%);
    color: #03111f;
    font-weight: 700;
    text-decoration: none;
  }

  .redirect-cta:hover,
  .redirect-cta:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(34, 197, 94, 0.28);
  }
</style>
