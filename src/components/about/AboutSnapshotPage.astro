function getStringSeed(value: string) {
  return Array.from(value).reduce((seed, char) => seed + char.charCodeAt(0), 0);
}

function getEntryStyle(entry: AboutPageEntry, index: number) {
  if (entry.presentation?.theme === 'youtube') {
    return '--entry-accent:var(--about-accent-youtube);--entry-accent-soft:var(--about-accent-youtube-soft);';
  }

  const accent = entryAccents[(getStringSeed(entry.id) + index) % entryAccents.length];
  return `--entry-accent:${accent};--entry-accent-soft:${accent};`;
}

function getEntryClass(entry: AboutPageEntry) {
  const classes = ['entry-item', `entry-kind-${entry.kind}`];

  if (entry.presentation?.theme === 'youtube') {
    classes.push('entry-item-youtube');
  }

  if (entry.kind === 'combo' || entry.kind === 'media') {
    classes.push('entry-item-with-preview');
  }

  return classes.join(' ');
}

function getPlatformIcon(entry: AboutPageEntry): PlatformIconDefinition | null {
  const iconKey = platformIconAliases[entry.id] ?? entry.id;
  return platformIcons[iconKey] ?? null;
}
---

<main class="about-page">
  <section class="about-sections">
    <div class="about-shell section-stack">
      {model.sections.map((section) => (
        <section class="section-block" id={`about-${section.id}`}>
          <header class="section-header">
            <h2>{section.title}</h2>
          </header>

          <div class="entry-list" role="list">
            {section.entries.map((entry, index) => {
              const platformIcon = getPlatformIcon(entry);

              return entry.href ? (
                <a
                  class={getEntryClass(entry)}
                  style={getEntryStyle(entry, index)}
                  href={entry.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  role="listitem"
                >
                  <div class="entry-main">
                    <div class="entry-heading">
                      <span class="entry-kind">{entry.kindLabel}</span>
                      <div class="entry-title-row">
                        {platformIcon ? (
                          <span
                            class={`entry-platform-icon entry-platform-icon-tone-${platformIcon.tone}`}
                            aria-hidden="true"
                          >
                            <svg viewBox={platformIcon.viewBox} focusable="false" aria-label={platformIcon.label}>
                              {platformIcon.shapes.map((shape) =>
                                shape.type === 'path' ? (
                                  <path
                                    d={shape.d}
                                    fill={shape.fill}
                                    stroke={shape.stroke}
                                    stroke-width={shape.strokeWidth}
                                    stroke-linecap={shape.strokeLinecap}
                                    stroke-linejoin={shape.strokeLinejoin}
                                    fill-rule={shape.fillRule}
                                    clip-rule={shape.clipRule}
                                    class={shape.className}
                                  />
                                ) : shape.type === 'circle' ? (
                                  <circle
                                    cx={shape.cx}
                                    cy={shape.cy}
                                    r={shape.r}
                                    fill={shape.fill}
                                    stroke={shape.stroke}
                                    stroke-width={shape.strokeWidth}
                                    class={shape.className}
                                  />
                                ) : (
                                  <text
                                    x={shape.x}
                                    y={shape.y}
                                    fill={shape.fill}
                                    font-size={shape.fontSize}
                                    font-weight={shape.fontWeight}
                                    letter-spacing={shape.letterSpacing}
                                    text-anchor={shape.textAnchor}
                                    class={shape.className}
                                  >
                                    {shape.value}
                                  </text>
                                ),
                              )}
                            </svg>
                          </span>
                        ) : null}
                        <h3>{entry.label}</h3>
                        {entry.presentation?.badgeLabel ? (
                          <span class="entry-brand-badge">{entry.presentation.badgeLabel}</span>
                        ) : null}
                      </div>
                    </div>

                    {entry.kind === 'contact' ? <p class="entry-value">{entry.value}</p> : null}
                    {entry.kind === 'combo' ? <p class="entry-value">{entry.value}</p> : null}

                    <p class="entry-detail">{entry.detail}</p>
                    {entry.linkText ? <p class="entry-link">{entry.linkText}</p> : null}
                  </div>

                  {entry.kind === 'media' || entry.kind === 'combo' ? (
                    <div class="entry-preview">
                      <img
                        src={entry.imageUrl}
                        alt={entry.alt}
                        width={entry.width}
                        height={entry.height}
                        loading="lazy"
                      />
                    </div>
                  ) : null}
                </a>
              ) : (
                <article class={getEntryClass(entry)} style={getEntryStyle(entry, index)} role="listitem">
                  <div class="entry-main">
                    <div class="entry-heading">
                      <span class="entry-kind">{entry.kindLabel}</span>
                      <div class="entry-title-row">
                        {platformIcon ? (
                          <span
                            class={`entry-platform-icon entry-platform-icon-tone-${platformIcon.tone}`}
                            aria-hidden="true"
                          >
                            <svg viewBox={platformIcon.viewBox} focusable="false" aria-label={platformIcon.label}>
                              {platformIcon.shapes.map((shape) =>
                                shape.type === 'path' ? (
                                  <path
                                    d={shape.d}
                                    fill={shape.fill}
                                    stroke={shape.stroke}
                                    stroke-width={shape.strokeWidth}
                                    stroke-linecap={shape.strokeLinecap}
                                    stroke-linejoin={shape.strokeLinejoin}
                                    fill-rule={shape.fillRule}
                                    clip-rule={shape.clipRule}
                                    class={shape.className}
                                  />
                                ) : shape.type === 'circle' ? (
                                  <circle
                                    cx={shape.cx}
                                    cy={shape.cy}
                                    r={shape.r}
                                    fill={shape.fill}
                                    stroke={shape.stroke}
                                    stroke-width={shape.strokeWidth}
                                    class={shape.className}
                                  />
                                ) : (
                                  <text
                                    x={shape.x}
                                    y={shape.y}
                                    fill={shape.fill}
                                    font-size={shape.fontSize}
                                    font-weight={shape.fontWeight}
                                    letter-spacing={shape.letterSpacing}
                                    text-anchor={shape.textAnchor}
                                    class={shape.className}
                                  >
                                    {shape.value}
                                  </text>
                                ),
                              )}
                            </svg>
                          </span>
                        ) : null}
                        <h3>{entry.label}</h3>
                        {entry.presentation?.badgeLabel ? (
                          <span class="entry-brand-badge">{entry.presentation.badgeLabel}</span>
                        ) : null}
                      </div>
                    </div>

                    {entry.kind === 'contact' ? <p class="entry-value">{entry.value}</p> : null}
                    {entry.kind === 'combo' ? <p class="entry-value">{entry.value}</p> : null}

                    <p class="entry-detail">{entry.detail}</p>
                    {entry.linkText ? <p class="entry-link">{entry.linkText}</p> : null}
                  </div>

                  {entry.kind === 'media' || entry.kind === 'combo' ? (
                    <div class="entry-preview">
                      <img
                        src={entry.imageUrl}
                        alt={entry.alt}
                        width={entry.width}
                        height={entry.height}
                        loading="lazy"
                      />
                    </div>
                  ) : null}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </section>
</main>

<style>
  .about-page {
    --page-border: color-mix(in srgb, var(--color-border) 100%, transparent);
    --page-surface: color-mix(in srgb, var(--color-surface-glass) 88%, var(--color-background) 12%);
    --page-surface-strong: color-mix(in srgb, var(--color-surface) 82%, var(--color-background) 18%);
    --page-foreground: var(--color-text);
    --page-text-soft: var(--color-text-secondary);
    --page-shadow: 0 20px 60px color-mix(in srgb, var(--color-background) 18%, transparent);
    --cyber-panel: linear-gradient(
      145deg,
      color-mix(in srgb, var(--page-surface-strong) 88%, var(--color-background) 12%) 0%,
      color-mix(in srgb, var(--page-surface) 92%, var(--color-background) 8%) 100%
    );
    --cyber-grid: linear-gradient(color-mix(in srgb, var(--color-border) 55%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--color-border) 45%, transparent) 1px, transparent 1px);
    --cyber-scan: repeating-linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-text) 0%, transparent) 0,
      color-mix(in srgb, var(--color-text) 0%, transparent) 9px,
      color-mix(in srgb, var(--color-primary) 8%, transparent) 10px,
      color-mix(in srgb, var(--color-primary) 8%, transparent) 11px
    );
    --cyber-glow: 0 0 0 1px color-mix(in srgb, var(--color-primary) 14%, transparent),
      0 18px 44px color-mix(in srgb, var(--color-background) 64%, transparent);
    --cyber-edge: color-mix(in srgb, var(--color-primary) 50%, var(--color-secondary) 50%);
    --about-accent-1: var(--color-primary);
    --about-accent-2: var(--color-secondary);
    --about-accent-3: var(--color-success);
    --about-accent-4: var(--color-accent);
    --about-accent-youtube: #ff3b30;
    --about-accent-youtube-soft: color-mix(in srgb, #ff3b30 76%, #ff8a7a 24%);
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--color-primary) 16%, transparent), transparent 30%),
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-secondary) 14%, transparent), transparent 24%),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-background) 92%, white 8%) 0%,
        color-mix(in srgb, var(--color-background) 96%, var(--color-surface) 4%) 100%
      );
    color: var(--page-foreground);
    min-height: 100vh;
  }

  [data-theme='dark'] .about-page {
    --page-surface: color-mix(in srgb, var(--color-surface-glass) 90%, var(--color-background) 10%);
    --page-surface-strong: color-mix(in srgb, var(--color-surface) 90%, var(--color-background) 10%);
    --page-foreground: var(--color-text);
    --page-text-soft: var(--color-text-secondary);
    --page-shadow: 0 24px 72px rgba(0, 0, 0, 0.32);
    --cyber-panel: linear-gradient(
      145deg,
      color-mix(in srgb, #07101f 82%, var(--color-primary) 18%) 0%,
      color-mix(in srgb, #050a15 84%, var(--color-secondary) 16%) 100%
    );
    --cyber-grid: linear-gradient(rgba(0, 212, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 255, 0.06) 1px, transparent 1px);
    --cyber-scan: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 10px,
      rgba(0, 212, 255, 0.08) 11px,
      rgba(0, 212, 255, 0.08) 12px
    );
    --cyber-glow: 0 0 0 1px rgba(0, 212, 255, 0.14), 0 18px 44px rgba(0, 0, 0, 0.62), 0 0 42px rgba(0, 212, 255, 0.08);
    --cyber-edge: color-mix(in srgb, var(--color-primary) 55%, var(--color-secondary) 45%);
    background:
      radial-gradient(circle at top left, rgba(0, 212, 255, 0.14), transparent 30%),
      radial-gradient(circle at top right, rgba(0, 255, 255, 0.12), transparent 24%),
      linear-gradient(180deg, #030712 0%, #07101f 42%, #030712 100%);
  }

  [data-theme='lunar-new-year'] .about-page {
    --page-surface: color-mix(in srgb, var(--color-surface-glass) 92%, var(--color-background) 8%);
    --page-surface-strong: color-mix(in srgb, var(--color-surface) 86%, var(--color-background) 14%);
    --page-foreground: var(--color-text);
    --page-text-soft: var(--color-text-secondary);
    --page-shadow: 0 24px 72px rgba(34, 5, 5, 0.24);
    --cyber-panel: linear-gradient(
      145deg,
      color-mix(in srgb, #5a1818 82%, var(--color-secondary) 18%) 0%,
      color-mix(in srgb, #3a0d0d 86%, var(--color-primary) 14%) 100%
    );
    --cyber-grid: linear-gradient(rgba(255, 213, 79, 0.11) 1px, transparent 1px),
      linear-gradient(90deg, rgba(229, 57, 53, 0.09) 1px, transparent 1px);
    --cyber-scan: repeating-linear-gradient(
      180deg,
      transparent 0,
      transparent 10px,
      rgba(255, 213, 79, 0.09) 11px,
      rgba(255, 213, 79, 0.09) 12px
