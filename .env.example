# Microsoft Clarity Analytics Configuration
# Get your project ID from https://clarity.microsoft.com
HAGICODE_CLARITY_PROJECT_ID=your_clarity_project_id_here

# 开发服务器端口配置
PORT_DOCS=31265
PORT_WEBSITE=31264

# ImgBin image generation defaults
IMGBIN_WORKDIR=../imgbin
IMGBIN_EXECUTABLE=../imgbin/dist/cli.js
IMGBIN_LIBRARY_ROOT=.imgbin-library
IMGBIN_ANALYSIS_PROVIDER=codex
IMGBIN_CODEX_MODEL=lemon/gpt-5.4
IMGBIN_CODEX_BASE_URL=http://localhost:36129/v1

# 活动数据更新脚本环境变量配置
# 复制此文件为 .env 并填入实际值

# Docker Hub 配置
DOCKER_HUB_REPOSITORY=newbe36524/hagicode

# Microsoft Clarity API 配置（用于获取活动数据）
CLARITY_API_KEY=your_clarity_api_key_here

# Docker Hub 认证（可选，如果需要认证的话）
# DOCKER_HUB_USERNAME=your_docker_hub_username
# DOCKER_HUB_PASSWORD=your_docker_hub_password
